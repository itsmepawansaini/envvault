{
  "name": "@itspawansaini/envvault",
  "version": "0.1.2",
  "description": "End-to-end encrypted .env sync for developers and small teams.",
  "keywords": [
    "env",
    "dotenv",
    "secrets",
    "secret-management",
    "configuration",
    "encryption",
    "cli",
    "developer-tools",
    "environment-variables"
  ],
  "license": "MIT",
  "author": {
    "name": "Pawan Saini",
    "email": "itspawansaini@gmail.com",
    "url": "https://www.itspawansaini.com"
  },
  "homepage": "https://github.com/itsmepawansaini/envvault#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsmepawansaini/envvault.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/itsmepawansaini/envvault/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "envvault": "dist/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.cjs",
    "check": "node --check src/index.js",
    "test": "npm run build && node --test src/index.test.js",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@envvault/crypto-core": "file:../../packages/crypto-core",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "esbuild": "^0.25.0",
    "prompts": "^2.4.2"
  }
}
