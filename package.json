{
  "name": "envvault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @envvault/web",
    "dev:api": "npm run dev --workspace @envvault/api",
    "cli": "npm run start --workspace @itspawansaini/envvault",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
